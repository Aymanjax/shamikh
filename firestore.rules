rules_version = '2';
service cloud.firestore {
  // القراءة لأي مستخدم مسجل
  match /{document=**} {
    allow read: if request.auth != null;
  }

  // كل مستخدم يكتب فقط ببياناته
  match /users/{userId}/{document=**} {
    allow write: if request.auth != null && request.auth.uid == userId;
  }

  // المدير يعدّل على أي حساب (اشتراك، حظر، صلاحية)
  match /users/{userId}/profile/main {
    allow write: if request.auth != null && (
      request.auth.uid == userId ||
      get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/main).data.role == 'admin'
    );
  }

  // users-public للقراءة والكتابة
  match /users-public/{userId} {
    allow read: if request.auth != null;
    allow write: if request.auth != null && request.auth.uid == userId;
  }

  // config يقرأه الجميع، يكتبه فقط المديرين
  match /config/{document} {
    allow read: if request.auth != null;
    allow write: if request.auth != null &&
      get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/main).data.role == 'admin';
  }

  // زوار الموقع - أي مستخدم مسجل يكتب
  match /visitors/{document} {
    allow write: if request.auth != null;
  }
}
