rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // أي مستخدم مسجل يقدر يقرأ
    match /{document=**} {
      allow read: if request.auth != null;
    }

    // كل مستخدم يكتب فقط ببياناته
    match /users/{userId}/{document=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // users-public يسمح للجميع بالقراءة والكتابة (للمستخدمين المسجلين)
    match /users-public/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // config يقرأه الجميع، يكتبه فقط المديرين
    match /config/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/main).data.role == 'admin';
    }
  }
}