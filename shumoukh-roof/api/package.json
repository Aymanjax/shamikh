{
  "name": "shumoukh-erp-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy": "gcloud functions deploy api --gen2 --runtime=nodejs20 --trigger-http --entry-point=api --source=. --allow-unauthenticated"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.17.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.0"
  }
}
