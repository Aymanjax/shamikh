# Firebase Admin SDK (service account JSON path)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Or provide individual fields:
FIREBASE_PROJECT_ID=shumoukh-erp
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@shumoukh-erp.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server config
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Roof skeleton Cloud Function URL (Python)
ROOF_SKELETON_API_URL=https://roof-skeletonize-xxxxx-uc.a.run.app
